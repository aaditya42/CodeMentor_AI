# ============================================
# CodeMentor AI — Environment Variables
# ============================================
# Copy to .env and fill in your values

# --- Database ---
DATABASE_URL="postgresql://codementor:codementor_pass@localhost:5432/codementor_db?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT Auth ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- AI Service (Python FastAPI) ---
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_TIMEOUT=90000

# --- Code Execution (Judge0 CE) ---
JUDGE0_URL="http://localhost:2358"

# --- AI Provider Keys (used by Python AI service) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEFAULT_PROVIDER="openai"
DEFAULT_MODEL="gpt-4o"
FALLBACK_PROVIDER="anthropic"
FALLBACK_MODEL="claude-sonnet-4-20250514"

# --- Embeddings (Python AI service) ---
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS=384

# --- FAISS Persistence ---
FAISS_INDEX_DIR="./data/faiss_indexes"
FAISS_PERSIST=true

# --- RAG Configuration ---
RAG_TOP_K=5
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6
RERANK_ENABLED=true
RERANK_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"

# --- Guardrails ---
SOLUTION_LEAKAGE_THRESHOLD=0.8
PROMPT_INJECTION_CHECK=true

# --- Server ---
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_NAME="CodeMentor AI"

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL="debug"
